# Salish Sea Dreaming — Gallery Server Configuration
# Copy to .env and fill in values before running
# DO NOT commit .env to git

TD_HOST=127.0.0.1
TD_OSC_PORT=7000
GALLERY_SERVER_PORT=8000
PROMPT_DWELL_SECONDS=30
MAX_QUEUE_SIZE=20

# Set a strong password before exhibition opens
ADMIN_PASSWORD=salishsea

# Base ecological prompt (no visitor input)
BASE_PROMPT=brionypenn watercolor painting, soft wet edges, natural pigment washes, ecological illustration, Salish Sea ecosystem

# Rate limiting
RATE_LIMIT_SECONDS=5

# Load testing bypass key — leave empty in production
RATE_LIMIT_BYPASS_KEY=

# Cloudflare Tunnel URL — confirmed on setup day (April 9)
TUNNEL_URL=https://ssd-gallery.cfargotunnel.com

# Audio device config — set after running: python scripts/gallery_audio.py --list-devices
AUDIO_DEVICE_INDEX=0
# RMS value that maps to 1.0 normalized — calibrate with clap test
AUDIO_PEAK_REFERENCE=0.1

# TouchDesigner operator name override — set if auto-discovery fails
# TD_OPERATOR_NAME=streamdiffusion1
