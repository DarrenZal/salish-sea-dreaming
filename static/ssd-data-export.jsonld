{
  "@context": {
    "schema": "https://schema.org/",
    "ssd": "https://salishseadreaming.art/ontology/"
  },
  "schema:name": "Salish Sea Dreaming -- Data Map",
  "schema:description": "Interactive knowledge graph for the Salish Sea Dreaming AI art installation",
  "schema:creator": "Salish Sea Dreaming Collective",
  "schema:datePublished": "2026-04-10",
  "schema:license": "mixed -- see per-asset licenses",
  "ssd:exhibition": "Digital Ecologies: Bridging Nature and Technology",
  "ssd:venue": "Mahon Hall, Salt Spring Island, BC",
  "ssd:url": "/graph",
  "@graph": [
    {
      "@id": "ssd:hub-ecosystem",
      "@type": "schema:Thing",
      "schema:name": "The Salish Sea",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "The Salish Sea ecosystem — a living web of salmon, herring, orca, kelp, and hundreds of interconnected species. The Five Threads weave through it."
    },
    {
      "@id": "ssd:hub-artists",
      "@type": "schema:Thing",
      "schema:name": "Artists & Witnesses",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "The artists and witnesses whose eyes, cameras, and brushes became the project’s sensory organs. Their work is the raw perception."
    },
    {
      "@id": "ssd:hub-training",
      "@type": "schema:Thing",
      "schema:name": "Training Corpus",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "1,255 images across 50 species — the visual corpus that trained the Dreaming GAN. Every image is CC-licensed or used with permission."
    },
    {
      "@id": "ssd:hub-machine",
      "@type": "schema:Thing",
      "schema:name": "The Dreaming Machine",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "The dreaming machine. Three projection layers: L1 = Moonfish footage cross-faded with ControlNet+LoRA style-transferred versions. L2 = StreamDiffusion real-time watercolor at 30fps. L3 = Raw Autolume GAN dreams. All composited in Resolume Arena onto the 8×8 ft wall."
    },
    {
      "@id": "ssd:hub-visitor-dreams",
      "@type": "schema:Thing",
      "schema:name": "Visitor Dreams",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "Your words become dreams. Speak or type at the QR portal — your vision travels through GPT filtering, OSC, and TouchDesigner to the projection wall. The machine renders your dream back to you. Bidirectional: your words travel to the machine; its dreams travel back to the wall."
    },
    {
      "@id": "ssd:hub-knowledge",
      "@type": "schema:Thing",
      "schema:name": "Knowledge & Research",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "Reports, data, and Indigenous knowledge that ground the project. The Kwaxala model. Three-Eyed Seeing. The herring story."
    },
    {
      "@id": "ssd:hub-exhibition",
      "@type": "schema:Thing",
      "schema:name": "The Exhibition",
      "ssd:nodeType": "hub",
      "ssd:tier": 0,
      "schema:description": "Digital Ecologies: Bridging Nature and Technology — Salt Spring Art Show at Mahon Hall, April 10–26, 2026."
    },
    {
      "@id": "ssd:concept-salmon",
      "@type": "schema:Thing",
      "schema:name": "Salmon",
      "ssd:nodeType": "concept",
      "ssd:tier": 0,
      "schema:description": "The salmon thread traces the great cycle — ocean to river to forest and back. Salmon carry marine nutrients deep into the watershed, feeding eagles, bears, and ancient cedars. Their return is the pulse of the coast.",
      "schema:alternateName": "Migration, cycles, return",
      "schema:isPartOf": "ssd:hub-ecosystem"
    },
    {
      "@id": "ssd:concept-herring",
      "@type": "schema:Thing",
      "schema:name": "Herring",
      "ssd:nodeType": "concept",
      "ssd:tier": 0,
      "schema:description": "Pacific herring are the foundation of the Salish Sea food web. Their spawning events — turning the water milky white — feed hundreds of species. DFO management set baselines from 1953, a year that was already catastrophic. Indigenous nations like the Heiltsuk challenged this, taking over their own stock assessment.",
      "schema:alternateName": "Foundation species — fishery tension, DFO",
      "schema:isPartOf": "ssd:hub-ecosystem"
    },
    {
      "@id": "ssd:concept-orca",
      "@type": "schema:Thing",
      "schema:name": "Orca",
      "ssd:nodeType": "concept",
      "ssd:tier": 0,
      "schema:description": "The Southern Resident orca pods (J, K, and L) are a family in crisis. Down to ~75 individuals, they face starvation from depleted Chinook salmon, toxic bioaccumulation, and vessel noise. Tahlequah (J35) carried her dead calf for 17 days in 2018 — a mourning procession witnessed around the world.",
      "schema:alternateName": "Family, grief, resilience — J/K/L pods",
      "schema:isPartOf": "ssd:hub-ecosystem"
    },
    {
      "@id": "ssd:concept-cedar",
      "@type": "schema:Thing",
      "schema:name": "Cedar",
      "ssd:nodeType": "concept",
      "ssd:tier": 1,
      "schema:description": "Cedar represents deep time. A single western red cedar can live over a thousand years. Cedar is the tree of life for Coast Salish peoples — canoes, longhouses, regalia, medicine. The cedar thread asks: what does it mean to plan on a thousand-year timescale?",
      "schema:alternateName": "Long time, patience — forest health",
      "schema:isPartOf": "ssd:hub-ecosystem"
    },
    {
      "@id": "ssd:concept-camas",
      "@type": "schema:Thing",
      "schema:name": "Camas",
      "ssd:nodeType": "concept",
      "ssd:tier": 1,
      "schema:description": "Camas meadows were tended by Coast Salish peoples for millennia — burned, harvested, replanted. Colonization disrupted these relationships. Today, camas restoration projects are healing the land and rebuilding reciprocal care. The camas thread is about what grows back when we tend it.",
      "schema:alternateName": "Restoration, community care — meadow restoration",
      "schema:isPartOf": "ssd:hub-ecosystem"
    },
    {
      "@id": "ssd:concept-three-eyed-seeing",
      "@type": "schema:Thing",
      "schema:name": "Three-Eyed Seeing",
      "ssd:nodeType": "concept",
      "ssd:tier": 0,
      "schema:description": "Three-Eyed Seeing integrates Western scientific observation, Indigenous Traditional Knowledge, and direct perception from the land itself. Not a hierarchy but a braiding — each eye sees what the others cannot.",
      "schema:alternateName": "Western science + Indigenous knowledge + the land itself",
      "schema:isPartOf": "ssd:hub-knowledge"
    },
    {
      "@id": "ssd:install-digital-ecologies",
      "@type": "schema:ExhibitionEvent",
      "schema:name": "Digital Ecologies",
      "ssd:nodeType": "installation",
      "ssd:tier": 0,
      "schema:description": "An interactive AI art installation exploring the Salish Sea ecosystem. The vision: not humans looking at nature through technology, but the Salish Sea using technology to perceive itself. Curated by Raf for the Digital Ecologies show.",
      "schema:alternateName": "Salt Spring Art Show — Mahon Hall, Apr 10–26, 2026",
      "schema:isPartOf": "ssd:hub-exhibition"
    },
