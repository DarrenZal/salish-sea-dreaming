    {
      "@id": "ssd:artifact-dreaming-gan",
      "@type": "schema:SoftwareApplication",
      "schema:name": "Dreaming GAN",
      "ssd:nodeType": "artifact",
      "ssd:tier": 1,
      "schema:description": "StyleGAN2-ada (320 kimg), ~1,255 images of 49 species. Abstract organic textures. Dual role: direct projection via Autolume + input to StreamDiffusion.",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
      "@id": "ssd:artifact-autolume",
      "@type": "schema:SoftwareApplication",
      "schema:name": "Autolume",
      "ssd:nodeType": "artifact",
      "ssd:tier": 1,
      "schema:description": "SFU MetaCreation Lab. Real-time latent space navigation. Audio-reactive, OSC. Layer 3 of projection: raw GAN dreams. Also feeds StreamDiffusion as img2img input.",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
      "@id": "ssd:node-touchdesigner",
      "@type": "schema:SoftwareApplication",
      "schema:name": "TouchDesigner",
      "ssd:nodeType": "software",
      "ssd:tier": 1,
      "schema:description": "Integration hub. Autolume video via NDI, visitor prompts via OSC. Prompt Sequencer cycles 23 ecological prompts (26s each, 6s crossfade). StreamDiffusion runs inside as TOX.",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
      "@id": "ssd:artifact-streamdiffusion",
      "@type": "schema:SoftwareApplication",
      "schema:name": "StreamDiffusion",
      "ssd:nodeType": "artifact",
      "ssd:tier": 1,
      "schema:description": "30fps img2img with SD-Turbo inside TD. Takes Autolume GAN output + 23 cycling prompts. Layer 2: real-time watercolor via Briony LoRA. Visitor dreams interrupt the cycle for 30s.",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
      "@id": "ssd:output-projection",
      "@type": "schema:Thing",
      "schema:name": "Projection",
      "ssd:nodeType": "output",
      "ssd:tier": 1,
      "schema:description": "The key node. 8×8 ft wall. Three layers in Resolume Arena: L1=Moonfish footage cross-faded with same footage through SD 1.5 + Briony LoRA + ControlNet depth (20 steps). L2=StreamDiffusion real-time watercolor. L3=Raw Autolume GAN.",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
      "@id": "ssd:node-gallery-server",
      "@type": "schema:SoftwareApplication",
      "schema:name": "Gallery Server",
      "ssd:nodeType": "software",
      "ssd:tier": 1,
      "schema:description": "FastAPI server. Processes visitor text through GPT-4.1-mini for content filtering. OSC to TouchDesigner. SQLite for submissions. SSE for live updates.",
      "schema:alternateName": "Visitor web app → OSC → TouchDesigner",
      "schema:isPartOf": "ssd:hub-machine"
    },
    {
